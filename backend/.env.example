# =============================================================================
# MailerOps - Backend Environment Variables
# =============================================================================

# Server Port
PORT=3000

# Node Environment (development | production)
NODE_ENV=development

# Database Type (sqlite | mongodb)
DATABASE_TYPE=sqlite

# SQLite Configuration
SQLITE_PATH=./data.sqlite

# MongoDB Configuration (Required if DATABASE_TYPE=mongodb)
MONGODB_URI=mongodb://localhost:27017/mailerops

# CORS Origin
CORS_ORIGIN=*

# JWT Secret (For future authentication)
JWT_SECRET=your_secret_key_here

# Shadow Intelligence Layer (Background Tasks)
# Interval in milliseconds (default: 600000 = 10 minutes)
IP_STATS_INTERVAL=600000

# Logging Level (debug | info | warn | error)
LOG_LEVEL=info
